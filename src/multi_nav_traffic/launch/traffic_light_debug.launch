<launch>
  <!-- ========================================================== -->
  <!--  红绿灯识别+测距 一键调试 launch                             -->
  <!--  用法: roslaunch multi_nav_traffic traffic_light_debug.launch-->
  <!--        roslaunch multi_nav_traffic traffic_light_debug.launch car_mode:=senior_diff -->
  <!-- ========================================================== -->

  <!-- 小车模式（与底盘启动保持一致） -->
  <arg name="car_mode" default="senior_diff"
       doc="opt: senior_diff, senior_akm, senior_mec_bs, senior_mec_dl, mini_omni, senior_omni, top_omni"/>

  <!-- ========== 1. 底盘底层（与 start_roscar.launch 一致） ========== -->

  <!-- 1.1 STM32 控制板驱动 -->
  <include file="$(find driver)/launch/car_driver.launch"/>

  <!-- 1.2 TF坐标系 + 机器人外形可视化 -->
  <include file="$(find start_roscar)/launch/robot_model_visualization.launch">
    <arg name="car_mode" value="$(arg car_mode)"/>
  </include>

  <!-- 1.3 激光雷达 RPLidar A3（波特率 256000，非 A1/A2 的 115200） -->
  <include file="$(find rplidar_ros)/launch/rplidar_a3.launch"/>

  <!-- 1.4 USB摄像头（/dev/video1，非默认的 video0） -->
  <node name="usb_cam" pkg="usb_cam" type="usb_cam_node" output="screen">
    <param name="video_device" value="/dev/video1"/>
    <param name="image_width" value="640"/>
    <param name="image_height" value="480"/>
    <param name="pixel_format" value="yuyv"/>
    <param name="camera_frame_id" value="camera_link"/>
    <param name="io_method" value="mmap"/>
    <remap from="/usb_cam/image_raw/compressed" to="/image_raw/compressed"/>
  </node>

  <!-- ========== 2. 红绿灯识别 + 测距节点 ========== -->
  <node pkg="multi_nav_traffic" type="multi_nav_traffic_light_node.py"
        name="traffic_light_debug" output="screen">

    <!-- ARM64: 修复 PyTorch 导入时的 TLS 内存分配错误 -->
    <env name="LD_PRELOAD" value="/usr/lib/aarch64-linux-gnu/libgomp.so.1"/>

    <!-- 调试模式（无显示器环境，关闭GUI窗口避免 cv2.imshow SIGABRT） -->
    <param name="use_mock_detection"    value="false"/>
    <param name="show_detection_window" value="false"/>

    <!-- YOLO 模型 -->
    <param name="model_path" value="$(find multi_nav_traffic)/model/best_new.pt"/>
    <param name="gamma"      value="1.5"/>
    <param name="confidence_threshold" value="0.5"/>

    <!-- TF帧 -->
    <param name="camera_frame" value="camera_link"/>
    <param name="laser_frame"  value="laser"/>
    <param name="robot_frame"  value="base_footprint"/>

    <!-- 红灯制动参数 -->
    <param name="stop_distance"    value="3.0"/>
    <param name="hold_distance"    value="1.5"/>
    <param name="safety_margin"    value="0.2"/>
    <param name="max_approach_vel" value="0.3"/>
    <param name="creep_vel"        value="0.05"/>

    <!-- 去抖滤波 -->
    <param name="red_debounce_frames"  value="3"/>
    <param name="green_confirm_frames" value="5"/>
    <param name="red_wait_timeout"     value="30.0"/>

    <!-- 距离滤波 -->
    <param name="angle_tolerance"        value="2.0"/>
    <param name="distance_filter_window" value="5"/>

    <!-- 相机内参（640x480 USB相机近似值） -->
    <param name="fx" value="550.0"/>
    <param name="fy" value="550.0"/>
    <param name="cx" value="320.0"/>
    <param name="cy" value="240.0"/>
  </node>

</launch>
